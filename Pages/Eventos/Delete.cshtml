@page
@model DW_26256_27229.Pages_Eventos.DeleteModel

@{
    ViewData["Title"] = "Apagar Evento";
}

<h1 class="fw-bold mb-4 text-danger">Apagar Evento</h1>

<div class="alert alert-danger shadow-sm mb-4 border-0" style="max-width: 650px;">
    <h5 class="alert-heading fw-bold mb-2">Atenção!</h5>
    <p class="mb-0">Tem a certeza absoluta que deseja apagar o evento <strong>@Html.DisplayFor(model => model.Evento.Titulo)</strong>? Todas as inscrições associadas a este evento também serão eliminadas. Esta ação não pode ser desfeita.</p>
</div>

<div class="card shadow-sm border-0 mb-4" style="max-width: 650px;">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-secondary align-self-center">Título</dt>
            <dd class="col-sm-8 fw-bold fs-5 text-dark mb-0">@Html.DisplayFor(model => model.Evento.Titulo)</dd>

            <dt class="col-sm-4 text-secondary mt-3">Data e Hora</dt>
            <dd class="col-sm-8 mt-3">@Html.DisplayFor(model => model.Evento.DataHora)</dd>

            <dt class="col-sm-4 text-secondary mt-3">Vagas Máximas</dt>
            <dd class="col-sm-8 mt-3">@Html.DisplayFor(model => model.Evento.VagasMaximas)</dd>

            <dt class="col-sm-4 text-secondary mt-3">Categoria</dt>
            <dd class="col-sm-8 mt-3">@Model.Evento.Categoria?.Nome</dd>
        </dl>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Evento.Id" />
    <div class="d-flex gap-2">
        <input type="submit" value="Sim, Apagar Evento" class="btn btn-danger fw-bold px-4" />
        <a asp-page="./Index" class="btn btn-outline-secondary fw-bold px-4">Cancelar e Voltar</a>
    </div>
</form>