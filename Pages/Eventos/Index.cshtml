@page
@model DW_26256_27229.Pages_Eventos.IndexModel

@{
    ViewData["Title"] = "Gestão de Eventos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold m-0">Eventos Disponíveis</h1>

    @if (User.FindFirst(System.Security.Claims.ClaimsIdentity.DefaultRoleClaimType)?.Value != "Aluno")
    {
        <a asp-page="Create" class="btn btn-primary fw-bold shadow-sm">
            + Criar Novo Evento
        </a>
    }
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <strong>✅ Sucesso!</strong> @TempData["MensagemSucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
        <strong>⚠️ Atenção:</strong> @TempData["MensagemErro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light">
            <tr>
                <th class="py-3 text-secondary">@Html.DisplayNameFor(model => model.Evento[0].Titulo)</th>
                <th class="py-3 text-secondary">Data e Hora</th>
                <th class="py-3 text-secondary">Vagas</th>
                <th class="py-3 text-secondary">Categoria</th>
                <th class="py-3 text-secondary text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Evento)
            {
                <tr>
                    <td class="fw-semibold text-dark">
                        @Html.DisplayFor(modelItem => item.Titulo)
                        @if (item.Inscricoes?.Count >= item.VagasMaximas)
                        {
                            <span class="badge bg-danger">Lotado</span>
                        }
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DataHora)
                    </td>
                    <td>
                        <span class="badge bg-info text-dark">@Html.DisplayFor(modelItem => item.VagasMaximas)</span>
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Categoria.Nome)
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">

                            @if (User.FindFirst(System.Security.Claims.ClaimsIdentity.DefaultRoleClaimType)?.Value ==
                                   "Aluno")
                            {
                                <form method="post" asp-page-handler="Inscrever" asp-route-id="@item.Id"
                                      style="display:inline;">
                                    <button type="submit" class="btn btn-outline-success fw-bold me-1" title="Inscrever-me">
                                        Inscrever
                                    </button>
                                </form>
                            }

                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-secondary"
                               title="Ver Detalhes">
                                Detalhes
                            </a>

                            @if (User.FindFirst(System.Security.Claims.ClaimsIdentity.DefaultRoleClaimType)?.Value !=
                                             "Aluno")
                            {
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Editar">
                                    Editar
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Apagar">
                                    Apagar
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav aria-label="Navegação de páginas de Eventos" class="mt-4">
    <ul class="pagination justify-content-center">
        
        @* Botão Anterior *@
        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
            <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex - 1)">
                Anterior
            </a>
        </li>

        @* Informação da Página Atual *@
        <li class="page-item disabled">
            <span class="page-link text-dark fw-bold">
                Página @Model.PageIndex de @Model.TotalPages
            </span>
        </li>

        @* Botão Seguinte *@
        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
            <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex + 1)">
                Seguinte
            </a>
        </li>
    </ul>
</nav>