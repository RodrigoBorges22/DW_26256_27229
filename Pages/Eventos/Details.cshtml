@page
@model DW_26256_27229.Pages_Eventos.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Evento</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Título
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Evento.Titulo)
        </dd>

        <dt class="col-sm-2">
            Data e Hora
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Evento.DataHora)
        </dd>

        <dt class="col-sm-2">
            Ocupação Atual
        </dt>
        <dd class="col-sm-10 fw-bold text-primary">
            @(Model.Evento.Inscricoes?.Count ?? 0) / @Model.Evento.VagasMaximas vagas preenchidas
        </dd>

        <dt class="col-sm-2">
            Categoria
        </dt>
        <dd class="col-sm-10">
            @Model.Evento.Categoria?.Nome
        </dd>
    </dl>
</div>
@if (User.FindFirst(System.Security.Claims.ClaimsIdentity.DefaultRoleClaimType)?.Value != "Aluno")
{
    <h4>Alunos Inscritos</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Data</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Evento.Inscricoes)
            {
                <tr>
                    <td>@item.Utilizador.Nome</td>
                    <td>@item.DataInscricao</td>
                </tr>
            }
        </tbody>
    </table>
}
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Evento.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
