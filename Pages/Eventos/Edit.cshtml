@page
@model DW_26256_27229.Pages_Eventos.EditModel

@{
    ViewData["Title"] = "Editar Evento";
}

<h1 class="fw-bold mb-4">Editar Evento</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Evento.Id" />
            <input type="hidden" asp-for="Evento.UtilizadorId" />

            <div class="form-group mb-3">
                <label asp-for="Evento.Titulo" class="control-label fw-semibold">Título</label>
                <input asp-for="Evento.Titulo" class="form-control py-2" />
                <span asp-validation-for="Evento.Titulo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Evento.DataHora" class="control-label fw-semibold">Data e Hora</label>
                <input asp-for="Evento.DataHora" class="form-control py-2" />
                <span asp-validation-for="Evento.DataHora" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Evento.VagasMaximas" class="control-label fw-semibold">Vagas Máximas</label>
                <input asp-for="Evento.VagasMaximas" class="form-control py-2" />
                <span asp-validation-for="Evento.VagasMaximas" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Evento.CategoriaId" class="control-label fw-semibold">Categoria</label>
                <select asp-for="Evento.CategoriaId" class="form-select py-2" asp-items="@(ViewData["CategoriaId"] as SelectList)"></select>
                <span asp-validation-for="Evento.CategoriaId" class="text-danger"></span>
            </div>

            <div class="form-group mt-4 d-flex gap-2">
                <input type="submit" value="Guardar Alterações" class="btn btn-success fw-bold px-4" />
                <a asp-page="./Index" class="btn btn-outline-secondary fw-bold px-4">Voltar à Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}