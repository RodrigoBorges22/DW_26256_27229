@page
@model DW_26256_27229.Pages_Categorias.EditModel

@{
    ViewData["Title"] = "Editar Categoria";
}

<h1 class="fw-bold mb-4">Editar Categoria</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <input type="hidden" asp-for="Categoria.Id" />

            <div class="form-group mb-4">
                <label asp-for="Categoria.Nome" class="control-label fw-semibold mb-1">Nome da Categoria</label>
                <input asp-for="Categoria.Nome" class="form-control py-2" />
                <span asp-validation-for="Categoria.Nome" class="text-danger"></span>
            </div>

            <div class="form-group d-flex gap-2">
                <input type="submit" value="Guardar Alterações" class="btn btn-success fw-bold px-4" />
                <a asp-page="./Index" class="btn btn-outline-secondary fw-bold px-4">Voltar à Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}