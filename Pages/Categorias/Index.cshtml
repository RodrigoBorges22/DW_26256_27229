@page
@model DW_26256_27229.Pages_Categorias.IndexModel

@{
    ViewData["Title"] = "Gestão de Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold m-0">Categorias</h1>
    
    <a asp-page="Create" class="btn btn-primary fw-bold shadow-sm">
        + Criar Nova Categoria
    </a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light">
            <tr>
                <th class="py-3 text-secondary">@Html.DisplayNameFor(model => model.Categoria[0].Nome)</th>
                <th class="py-3 text-secondary text-center" style="width: 250px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categoria) {
                <tr>
                    <td class="fw-semibold text-dark">
                        @Html.DisplayFor(modelItem => item.Nome)
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Editar">
                                Editar
                            </a>
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Ver Detalhes">
                                Detalhes
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Apagar">
                                Apagar
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>