@page
@model DW_26256_27229.Pages_Categorias.DetailsModel

@{
    ViewData["Title"] = "Detalhes da Categoria";
}

<h1 class="fw-bold mb-4">Detalhes da Categoria</h1>

<div class="card shadow-sm border-0 mb-4" style="max-width: 600px;">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-secondary align-self-center">
                Nome da Categoria
            </dt>
            <dd class="col-sm-8 fw-bold fs-5 text-dark mb-0">
                @Html.DisplayFor(model => model.Categoria.Nome)
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-page="./Edit" asp-route-id="@Model.Categoria?.Id" class="btn btn-primary fw-bold px-4">Editar</a>
    <a asp-page="./Index" class="btn btn-outline-secondary fw-bold px-4">Voltar à Lista</a>
</div>