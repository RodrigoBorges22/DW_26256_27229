@page
@model DW_26256_27229.Pages.RegistoModel
@{
    ViewData["Title"] = "Registo";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <div class="card-body">
                    <h2 class="text-center fw-bold mb-4">Registar como @Model.Tipo</h2>
                    
                    <form method="post">
                        <input type="hidden" asp-for="Tipo" />

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-semibold">Nome Completo</label>
                            <input asp-for="Nome" class="form-control py-2" placeholder="O seu nome" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" type="email" class="form-control py-2" placeholder="O seu email" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold">Palavra-passe</label>
                            <input asp-for="Password" type="password" class="form-control py-2" placeholder="Crie uma palavra-passe" required />
                        </div>

                        <button type="submit" class="btn @(Model.Tipo == "Professor" ? "btn-primary" : "btn-success") w-100 py-2.5 fw-bold rounded-3 mb-4">
                            Criar Conta
                        </button>

                        <hr class="text-muted" />

                        <div class="text-center mt-3">
                            <p class="mb-0 text-muted">
                                Já tem conta? 
                                <a asp-page="/Login" asp-route-tipo="@Model.Tipo" class="text-decoration-none fw-bold @(Model.Tipo == "Professor" ? "text-primary" : "text-success")">
                                    Entre aqui!
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>