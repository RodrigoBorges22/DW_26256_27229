@page
@model DW_26256_27229.Pages_Inscricoes.IndexModel

@{
    ViewData["Title"] = "As Minhas Inscrições";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold m-0">As Minhas Inscrições</h1>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0 bg-white">
        <thead class="table-light">
            <tr>
                <th class="py-3 text-secondary">
                    @Html.DisplayNameFor(model => model.Inscricao[0].Utilizador)
                </th>
                <th class="py-3 text-secondary">
                    @Html.DisplayNameFor(model => model.Inscricao[0].Evento)
                </th>
                <th class="py-3 text-secondary">
                    Data de Inscrição
                </th>
                <th class="py-3 text-secondary text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Inscricao)
            {
                <tr>
                    <td class="text-dark">
                        @Html.DisplayFor(modelItem => item.Utilizador.Nome)
                    </td>
                    <td class="fw-semibold text-primary">
                        @Html.DisplayFor(modelItem => item.Evento.Titulo)
                    </td>
                    <td class="text-muted">
                        @Html.DisplayFor(modelItem => item.DataInscricao)
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            @* O link do botão Detalhes passa agora as duas chaves *@
                            <a asp-page="./Details" asp-route-eventoId="@item.EventoId" asp-route-utilizadorId="@item.UtilizadorId" class="btn btn-outline-secondary" title="Ver Detalhes da Inscrição">
                                Detalhes
                            </a>
                            
                            @* O link do botão Cancelar passa agora as duas chaves *@
                            <a asp-page="./Delete" asp-route-eventoId="@item.EventoId" asp-route-utilizadorId="@item.UtilizadorId" class="btn btn-outline-danger fw-bold" title="Cancelar Inscrição">
                                Cancelar Inscrição
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>